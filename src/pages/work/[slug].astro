---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const items = await getCollection('work');
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<Base
  title={`${d.title} — Juan Contreras`}
  description={d.blurb}
  current="work"
  ogTitle={`${d.title} — Case study`}
  ogDescription={d.blurb}
  ogImage={d.og}
>
  <article class="case">
    <div class="container">
      <a class="back" href="/#work">← All work</a>

      <header class="case-head">
        <div class="case-meta">
          <span class="status" data-status={d.status}>{d.status}</span>
          <span class="year">{d.year}</span>
        </div>
        <h1>{d.title}</h1>
        <p class="lead">{d.blurb}</p>
        <ul class="tags" aria-label="Technologies">
          {d.tags.map((t) => <li>{t}</li>)}
        </ul>
        {
          (d.live || d.repo) && (
            <div class="links">
              {d.live && (
                <a class="btn btn-primary" href={d.live} target="_blank" rel="noopener noreferrer">
                  Visit live site →
                </a>
              )}
              {d.repo && (
                <a class="btn btn-secondary" href={d.repo} target="_blank" rel="noopener noreferrer">
                  View repo
                </a>
              )}
            </div>
          )
        }
      </header>

      {
        d.image && (
          <figure class="shot reveal">
            <img src={d.image} alt={d.imageAlt ?? `${d.title} screenshot`} width="1280" height="720" loading="eager" />
          </figure>
        )
      }

      <div class="case-body">
        <Content />
      </div>

      <footer class="case-foot reveal">
        <h2>Stack</h2>
        <p class="stack">{d.stack}</p>
        <div class="links">
          {d.live && (
            <a class="btn btn-primary" href={d.live} target="_blank" rel="noopener noreferrer">
              Visit live site →
            </a>
          )}
          {d.repo && (
            <a class="btn btn-secondary" href={d.repo} target="_blank" rel="noopener noreferrer">
              View repo
            </a>
          )}
          <a class="btn btn-secondary" href="/#contact">Start a project</a>
        </div>
      </footer>
    </div>
  </article>
</Base>

<style>
  .case {
    padding: 3rem 0 4rem;
  }

  .back {
    display: inline-block;
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .back:hover {
    color: var(--red);
  }

  .case-head {
    max-width: 760px;
  }

  .case-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  .status {
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .status[data-status='Live'] {
    color: var(--ok, #3ad29f);
    border-color: color-mix(in srgb, var(--ok, #3ad29f) 45%, transparent);
  }

  .status[data-status='In progress'] {
    color: #e8b341;
    border-color: color-mix(in srgb, #e8b341 45%, transparent);
  }

  .year {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-faint);
  }

  .case-head h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .lead {
    color: var(--text-muted);
    font-size: 1.15rem;
    margin-top: 1rem;
  }

  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.25rem 0 0;
  }

  .tags li {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.55rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.75rem;
  }

  .shot {
    margin: 2.5rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }

  .shot img {
    width: 100%;
    height: auto;
    display: block;
  }

  .case-body {
    max-width: 760px;
  }

  .case-body :global(h2) {
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    margin: 2.25rem 0 0.85rem;
  }

  .case-body :global(h2::before) {
    content: '// ';
    color: var(--red);
    font-family: var(--mono);
    font-size: 0.95rem;
  }

  .case-body :global(p) {
    color: var(--text-muted);
    margin-top: 0.6rem;
  }

  .case-body :global(ul) {
    color: var(--text-muted);
    margin: 0.6rem 0 0 1.1rem;
    line-height: 1.8;
  }

  .case-body :global(strong) {
    color: var(--text);
  }

  .case-body :global(em) {
    color: var(--text-faint);
  }

  .case-body :global(code) {
    font-family: var(--mono);
    font-size: 0.88em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  .case-foot {
    max-width: 760px;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .case-foot h2 {
    font-size: 1.05rem;
    font-family: var(--mono);
    color: var(--text-faint);
    text-transform: lowercase;
  }

  .case-foot h2::before {
    content: '// ';
    color: var(--red);
  }

  .stack {
    color: var(--text-muted);
    margin-top: 0.6rem;
    font-size: 0.97rem;
  }
</style>
