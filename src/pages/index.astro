<script>
  // Progressive enhancement on top of the pure-CSS :target tabs: highlight the active tab,
  // reset scroll on switch, and close the mobile menu. Tabs still work with JS disabled.
  const panels = Array.from(document.querySelectorAll('.tab-panel'));
  const ids = new Set(panels.map((p) => p.id));
  const navLinks = Array.from(document.querySelectorAll('.nav-link'));

  function activeId() {
    const id = (location.hash || '#home').slice(1);
    return ids.has(id) ? id : 'home';
  }

  function sync() {
    const id = activeId();
    navLinks.forEach((a) => {
      const href = a.getAttribute('href') || '';
      if (href.endsWith('#' + id)) a.setAttribute('aria-current', 'page');
      else a.removeAttribute('aria-current');
    });
    window.scrollTo({ top: 0 });
    const menu = document.getElementById('nav-menu');
    const ham = document.getElementById('hamburger');
    if (menu && menu.classList.contains('open')) {
      menu.classList.remove('open');
      if (ham) {
        ham.setAttribute('aria-expanded', 'false');
        ham.setAttribute('aria-label', 'Open menu');
      }
    }
  }

  sync();
  window.addEventListener('hashchange', sync);
</script>
