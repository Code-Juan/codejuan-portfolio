---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);

const skills = [
  { group: 'Frontend', items: 'HTML, CSS, JavaScript / TypeScript, Astro' },
  { group: 'Backend', items: 'Node.js, Express, REST APIs, Postgres' },
  { group: 'Apps', items: 'Flutter, Dart, SQLite, Supabase' },
  { group: 'Ops & quality', items: 'GitHub Pages / Actions, security hardening, SEO, accessibility' },
];
---

<Base
  title="Juan Contreras — Software Developer & Web Builder"
  description="Juan Contreras builds fast, modern websites and cross-platform apps for small businesses. Game-dev and systems background; performance-obsessed."
  current="home"
>
  <!-- hero -->
  <section class="hero section" id="home">
    <div class="container">
      <span class="eyebrow">// portfolio</span>
      <h1 class="hero-title">Juan Contreras</h1>
      <p class="hero-tagline">
        I build fast, modern websites and cross-platform apps for small businesses. A background in game
        development and systems programming means I care about performance, clean code, and shipping things that
        actually work.
      </p>
      <div class="hero-cta">
        <a href="#work" class="btn btn-primary btn-large">See my work</a>
        <a href="#contact" class="btn btn-secondary btn-large">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- work -->
  <section class="section work" id="work">
    <div class="container">
      <span class="eyebrow">// selected work</span>
      <h2 class="section-title">Real projects, real links</h2>
      <p class="section-subtitle">Three recent builds — each with a full case study.</p>
      <div class="work-grid">
        {
          projects.map((p) => (
            <a class="work-card reveal" href={`/work/${p.id}.html`}>
              {p.data.image && (
                <img
                  class="work-shot"
                  src={p.data.image}
                  alt={p.data.imageAlt ?? p.data.title}
                  width="640"
                  height="360"
                  loading="lazy"
                />
              )}
              <div class="work-card-body">
                <div class="work-card-meta">
                  <span class="status" data-status={p.data.status}>
                    {p.data.status}
                  </span>
                  <span class="year">{p.data.year}</span>
                </div>
                <h3>{p.data.title}</h3>
                <p>{p.data.blurb}</p>
                <div class="work-tags">
                  {p.data.tags.map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
                <span class="work-link">Read case study →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- skills -->
  <section class="section skills" id="skills">
    <div class="container">
      <span class="eyebrow">// what I work with</span>
      <h2 class="section-title">Tools, proven on the work above</h2>
      <div class="skills-grid">
        {
          skills.map((s) => (
            <div class="skill reveal">
              <h3>{s.group}</h3>
              <p>{s.items}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- about -->
  <section class="section about" id="about">
    <div class="container">
      <span class="eyebrow">// about</span>
      <h2 class="section-title">Hi, I'm Juan</h2>
      <div class="about-body">
        <p>
          I'm a software developer who specializes in building for small businesses — from marketing sites to full
          applications. My background in game development and systems programming gives me a real bias toward
          performance and clean, maintainable code.
        </p>
        <p>
          I started CodeJuan Web Services because too many small businesses get overcharged for slow, templated
          sites. I'd rather build something fast, honest, and genuinely useful.
        </p>
        <p>
          Looking for a business website or pricing?
          <a href="https://services.codejuan.com">See CodeJuan Web Services →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- contact -->
  <section class="section contact" id="contact">
    <div class="container contact-inner">
      <span class="eyebrow">// contact</span>
      <h2 class="section-title">Let's build something</h2>
      <p class="section-subtitle">Have a project in mind, or just want to talk? I'll get back to you within 24 hours.</p>
      <a class="btn btn-primary btn-large" href="mailto:contact@codejuan.com">contact@codejuan.com</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: 5rem;
  }

  .hero-title {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .hero-tagline {
    color: var(--text-muted);
    max-width: 640px;
    margin-top: 1.25rem;
    font-size: 1.1rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  /* work cards */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .work-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
  }

  .work-shot {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
    border-bottom: 1px solid var(--border);
    background: var(--bg-raised);
  }

  .work-card-body {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex-grow: 1;
  }

  .work-card-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .status {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .status[data-status='Live'] {
    color: var(--ok, #3ad29f);
    border-color: color-mix(in srgb, var(--ok, #3ad29f) 45%, transparent);
  }

  .status[data-status='In progress'] {
    color: #e8b341;
    border-color: color-mix(in srgb, #e8b341 45%, transparent);
  }

  .year {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-faint);
  }

  .work-card h3 {
    font-size: 1.2rem;
  }

  .work-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .work-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.12rem 0.5rem;
  }

  .work-link {
    color: var(--red);
    font-weight: 600;
    font-size: 0.92rem;
    margin-top: 0.3rem;
  }

  /* skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .skill {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .skill h3 {
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--text-faint);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .skill h3::before {
    content: '// ';
    color: var(--red);
  }

  .skill p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 0.5rem;
  }

  /* about */
  .about-body {
    max-width: 640px;
  }

  .about-body p {
    color: var(--text-muted);
    margin-top: 1rem;
  }

  .about-body a {
    color: var(--red);
    text-decoration: none;
  }

  /* contact */
  .contact-inner {
    text-align: center;
  }

  .contact .btn {
    margin-top: 1.5rem;
  }

  @media (max-width: 980px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 880px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
