---
import Base from '../layouts/Base.astro';

// Game-development projects, recovered from the original codejuan.com and re-presented in the new design.
// Descriptions only (no media/links), grouped by category — mirrors the original structure.
const categories = [
  {
    name: 'Unity Projects',
    games: [
      {
        title: 'Project Galaxy',
        tech: 'Unity 2022.3.53f1 · C# · 3D',
        bullets: [
          'Player movement with physics and AI enemies driven by NavMeshAgent',
          'Weapon systems, health/damage, and inventory management',
          'Mission objectives and save/load functionality',
          'Scene management with async loading',
        ],
        tags: ['Unity', 'C#', '3D Game Dev', 'AI Systems'],
      },
    ],
  },
  {
    name: 'Unreal Projects',
    games: [
      {
        title: 'END2508 — Unreal Engine C++',
        tech: 'Unreal Engine 5 · C++ · Component-based',
        bullets: [
          'Base character class with inheritance and a health component system',
          'Weapon system built with child actors',
          'Event-driven architecture and animation blueprint integration',
          'Input handling with proper memory management',
        ],
        tags: ['Unreal Engine', 'C++', 'Component Systems', 'Memory Management'],
      },
    ],
  },
  {
    name: 'C++ & Algorithms',
    games: [
      {
        title: 'C++ Data Structures',
        tech: 'C++ · Advanced Algorithms',
        bullets: [
          'Dynamic arrays, linked lists, binary search trees',
          'Hash tables and Huffman coding',
          'RAII principles and unit testing',
          'Performance optimization and recursive algorithms',
        ],
        tags: ['C++', 'Algorithms', 'Data Structures', 'Memory Management'],
      },
    ],
  },
];

const skills = [
  { group: 'Engines', items: 'Unity, Unreal Engine 5' },
  { group: 'Languages', items: 'C++, C#, Dart, JavaScript / TypeScript' },
  { group: 'Game systems', items: 'AI (NavMeshAgent), physics, gameplay, save/load, inventory' },
  { group: 'Foundations', items: 'Data structures & algorithms, memory management, RAII' },
];
---

<Base
  title="Juan Contreras — Game Programmer & Software Developer"
  description="Game programmer building immersive games with C++ and C#, Unity and Unreal Engine — plus cross-platform applications."
  current="home"
>
  <!-- hero -->
  <section class="hero section" id="home">
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="eyebrow">// game developer</span>
        <h1 class="hero-title">Juan Contreras</h1>
        <p class="hero-sub">Game Programmer &amp; Software Developer</p>
        <p class="hero-tagline">
          Building immersive games with C++ and C#, in Unity and Unreal Engine — with complete systems for AI,
          physics, and gameplay. Systems-programming roots, performance-obsessed.
        </p>
        <div class="hero-cta">
          <a href="#games" class="btn btn-primary btn-large">View my games</a>
          <a href="#contact" class="btn btn-secondary btn-large">Get in touch</a>
        </div>
      </div>
      <img class="hero-mascot" src="/images/mascot.png" alt="" width="613" height="560" loading="eager" />
    </div>
  </section>

  <!-- game development -->
  <section class="section games" id="games">
    <div class="container">
      <span class="eyebrow">// game development</span>
      <h2 class="section-title">Game Development Portfolio</h2>
      <p class="section-subtitle">Game projects and technical work in Unity, Unreal Engine, and C++.</p>

      {
        categories.map((cat) => (
          <div class="game-category">
            <h3 class="category-title">{cat.name}</h3>
            <div class="games-grid">
              {cat.games.map((g) => (
                <article class="game-card reveal">
                  <h4>{g.title}</h4>
                  <p class="game-tech">{g.tech}</p>
                  <ul class="game-bullets">
                    {g.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                  <div class="game-tags">
                    {g.tags.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- skills -->
  <section class="section skills" id="skills">
    <div class="container">
      <span class="eyebrow">// what I work with</span>
      <h2 class="section-title">Tools & systems</h2>
      <div class="skills-grid">
        {
          skills.map((s) => (
            <div class="skill reveal">
              <h3>{s.group}</h3>
              <p>{s.items}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- about -->
  <section class="section about" id="about">
    <div class="container">
      <span class="eyebrow">// about</span>
      <h2 class="section-title">Hi, I'm Juan</h2>
      <div class="about-body">
        <p>
          I'm a game programmer and software developer. My journey began with C++ fundamentals and data
          structures, then expanded into game development with Unity and Unreal Engine — building complete 3D games
          with complex systems including AI, physics, and gameplay mechanics.
        </p>
        <p>
          Whether I'm optimizing game performance, implementing complex algorithms, or building scalable
          applications, I care about clean architecture and code that holds up.
        </p>
      </div>
    </div>
  </section>

  <!-- contact -->
  <section class="section contact" id="contact">
    <div class="container contact-inner">
      <span class="eyebrow">// contact</span>
      <h2 class="section-title">Let's build something</h2>
      <p class="section-subtitle">
        A game studio looking for a programmer, a team seeking a collaborator, or a project in mind — I'd love to
        hear from you.
      </p>
      <a class="btn btn-primary btn-large" href="mailto:contact@codejuan.com">contact@codejuan.com</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2rem;
  }

  .hero-title {
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.04;
  }

  .hero-sub {
    font-family: var(--mono);
    color: var(--red);
    font-size: 1.05rem;
    margin-top: 0.75rem;
  }

  .hero-tagline {
    color: var(--text-muted);
    max-width: 560px;
    margin-top: 1.1rem;
    font-size: 1.08rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-mascot {
    width: 100%;
    max-width: 360px;
    height: auto;
    justify-self: center;
    filter: drop-shadow(0 12px 26px rgba(0, 0, 0, 0.45));
  }

  :global(html.js[data-motion='full']) .hero-mascot {
    animation: bob 5s ease-in-out infinite;
  }

  @keyframes bob {
    50% {
      transform: translateY(-8px);
    }
  }

  /* games */
  .game-category {
    margin-top: 2.5rem;
  }

  .category-title {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-faint);
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .category-title::before {
    content: '// ';
    color: var(--red);
  }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .game-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
  }

  .game-card h4 {
    font-size: 1.2rem;
  }

  .game-tech {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--red);
    margin-top: 0.35rem;
  }

  .game-bullets {
    color: var(--text-muted);
    margin: 0.9rem 0 0 1.1rem;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .game-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.12rem 0.5rem;
  }

  /* skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .skill {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .skill h3 {
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--text-faint);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .skill h3::before {
    content: '// ';
    color: var(--red);
  }

  .skill p {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 0.5rem;
  }

  /* about */
  .about-body {
    max-width: 640px;
  }

  .about-body p {
    color: var(--text-muted);
    margin-top: 1rem;
  }

  /* contact */
  .contact-inner {
    text-align: center;
  }

  .contact .btn {
    margin-top: 1.5rem;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-mascot {
      max-width: 260px;
      order: -1;
    }

    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
