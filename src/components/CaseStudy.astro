---
// Shell for a game case-study page: header meta block + hero art, with the
// write-up sections passed in as slot content.
interface Link {
  label: string;
  href: string;
}

interface Props {
  status: string;
  title: string;
  tagline: string;
  meta: { label: string; value: string }[];
  tags: string[];
  links?: Link[];
  image?: { src: string; alt: string; width: number; height: number };
  imageCaption?: string;
}

const { status, title, tagline, meta, tags, links = [], image, imageCaption } = Astro.props;
---

<article class="case">
  <div class="container case-inner">
    <a class="back" href="/#games">&larr; All games</a>

    <header class="case-header">
      <span class="chip">{status}</span>
      <h1>{title}</h1>
      <p class="tagline">{tagline}</p>

      <dl class="meta">
        {
          meta.map((m) => (
            <div class="meta-item">
              <dt>{m.label}</dt>
              <dd>{m.value}</dd>
            </div>
          ))
        }
      </dl>

      <div class="tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>

      {
        links.length > 0 && (
          <div class="links">
            {links.map((l) => (
              <a
                class="btn btn-secondary"
                href={l.href}
                target={l.href.startsWith('http') ? '_blank' : undefined}
                rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                {l.label}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      image && (
        <figure class="art">
          <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="eager" />
          {imageCaption && <figcaption>{imageCaption}</figcaption>}
        </figure>
      )
    }

    <div class="body">
      <slot />
    </div>
  </div>
</article>

<style>
  .case {
    padding: 3rem 0 5rem;
  }

  .case-inner {
    max-width: 860px;
  }

  .back {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back:hover {
    color: var(--red-text);
  }

  .case-header {
    margin-top: 1.6rem;
  }

  .chip {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--red-text);
    border: 1px solid var(--red-text);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.6rem;
  }

  .case-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 0.8rem;
  }

  .tagline {
    color: var(--text-muted);
    font-size: 1.08rem;
    max-width: 640px;
    margin-top: 0.7rem;
  }

  .meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1rem;
    margin-top: 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.1rem 1.25rem;
  }

  .meta-item dt {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    color: var(--text-faint);
  }

  .meta-item dt::before {
    content: '// ';
    color: var(--red-text);
  }

  .meta-item dd {
    color: var(--text);
    font-size: 0.92rem;
    margin-top: 0.25rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.12rem 0.5rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .art {
    margin-top: 2.2rem;
  }

  .art img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .art figcaption {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-faint);
    margin-top: 0.5rem;
  }

  /* slotted write-up sections (scoped styles don't reach slot content) */
  .body :global(h2) {
    font-family: var(--mono);
    font-size: 0.9rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    color: var(--text-faint);
    margin-top: 2.6rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.45rem;
  }

  .body :global(h2::before) {
    content: '// ';
    color: var(--red-text);
  }

  .body :global(p) {
    color: var(--text-muted);
    margin-top: 1rem;
  }

  .body :global(ul) {
    margin: 1rem 0 0 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .body :global(li) {
    margin-top: 0.55rem;
  }

  .body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .body :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.05rem 0.35rem;
  }

  /* callout for debugging stories */
  .body :global(.story) {
    border: 1px solid var(--border);
    border-left: 3px solid var(--red);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.1rem 1.3rem;
    margin-top: 1.2rem;
  }

  .body :global(.story h3) {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .body :global(.story p) {
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }
</style>
